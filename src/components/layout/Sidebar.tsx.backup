import { Monitor, List, Calendar, Layers, Library, Settings, ChevronDown, LogOut } from 'lucide-react';
import { Button } from '@/components/ui/button';
import {
  Collapsible,
  CollapsibleContent,
  CollapsibleTrigger,
} from '@/components/ui/collapsible';
import { useState } from 'react';
import { useAuth } from '@/contexts/AuthContext';
import { toast } from 'sonner';
import { MediaLibraryModal } from '@/components/media-library/MediaLibraryModal';

const navigationItems = [
  { name: 'Écrans', icon: Monitor, path: '/screens' },
  { name: 'Playlists', icon: List, path: '/playlists' },
  { name: 'Programmation', icon: Calendar, path: '/programmation' },
  { name: 'Séquence', icon: Layers, path: '/sequence' },
];

const settingsItems = [
  'Profil',
  'Entreprise',
  'Équipe',
  'Factures',
  'Intégration',
];

export function Sidebar() {
  const [settingsOpen, setSettingsOpen] = useState(false);
  const [currentPath, setCurrentPath] = useState(window.location.hash.slice(1) || '/screens');
  const [mediaLibraryOpen, setMediaLibraryOpen] = useState(false);
  const { signOut, user } = useAuth();

  const handleSignOut = async () => {
    try {
      await signOut();
      toast.success('Déconnexion réussie');
      window.location.hash = '/login';
    } catch (error) {
      console.error('Sign out error:', error);
      toast.error('Erreur lors de la déconnexion');
    }
  };

  const handleNavigate = (path: string) => {
    window.location.hash = path;
    setCurrentPath(path);
  };

  return (
    <aside className="w-64 h-screen bg-white border-r border-gray-200 flex flex-col">
      <div className="p-4 border-b border-gray-200">
        <Button
          variant="outline"
          className="w-full justify-between h-12 rounded-xl"
        >
          <div className="flex items-center gap-3">
            <div className="w-8 h-8 rounded-full bg-pink-100 flex items-center justify-center text-pink-600 font-semibold">
              {user?.email?.[0]?.toUpperCase() || 'M'}
            </div>
            <span className="font-semibold truncate max-w-[140px]">
              {user?.email?.split('@')[0] || 'Montet'}
            </span>
          </div>
          <ChevronDown className="h-4 w-4 text-gray-500" />
        </Button>
      </div>

      <nav className="flex-1 p-4 space-y-1">
        {navigationItems.map((item) => {
          const isActive = currentPath === item.path || currentPath.startsWith(item.path + '/');
          return (
            <Button
              key={item.name}
              variant={isActive ? 'secondary' : 'ghost'}
              onClick={() => handleNavigate(item.path)}
              className={`w-full justify-start h-11 rounded-xl font-medium ${
                isActive ? 'bg-gray-100' : 'text-gray-600'
              }`}
            >
              <item.icon className="h-5 w-5 mr-3" />
              {item.name}
            </Button>
          );
        })}

        <Button
          variant="ghost"
          onClick={() => setMediaLibraryOpen(true)}
          className="w-full justify-start h-11 rounded-xl text-gray-600 font-medium"
        >
          <Library className="h-5 w-5 mr-3" />
          Média librairie
        </Button>

        <Collapsible open={settingsOpen} onOpenChange={setSettingsOpen}>
          <CollapsibleTrigger asChild>
            <Button
              variant="ghost"
              className="w-full justify-between h-11 rounded-xl text-gray-600 font-medium"
            >
              <div className="flex items-center">
                <Settings className="h-5 w-5 mr-3" />
                Paramètres
              </div>
              <ChevronDown
                className={`h-4 w-4 transition-transform ${
                  settingsOpen ? 'rotate-180' : ''
                }`}
              />
            </Button>
          </CollapsibleTrigger>
          <CollapsibleContent className="ml-8 mt-1 space-y-1">
            {settingsItems.map((item) => (
              <Button
                key={item}
                variant="ghost"
                className="w-full justify-start h-9 rounded-lg text-sm text-gray-600"
              >
                {item}
              </Button>
            ))}
          </CollapsibleContent>
        </Collapsible>

        <Button
          variant="ghost"
          onClick={handleSignOut}
          className="w-full justify-start h-11 rounded-xl text-red-600 font-medium hover:text-red-700 hover:bg-red-50"
        >
          <LogOut className="h-5 w-5 mr-3" />
          Déconnexion
        </Button>
      </nav>

      <div className="p-4 space-y-3">
        <div className="bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl p-4 text-white relative overflow-hidden">
          <div className="relative z-10">
            <div className="text-sm font-medium mb-1">Juuno</div>
            <div className="text-xs mb-2">Quick start guide</div>
            <div className="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center">
              <div className="w-0 h-0 border-l-[6px] border-l-white border-t-[4px] border-t-transparent border-b-[4px] border-b-transparent ml-1" />
            </div>
          </div>
          <div className="absolute top-2 right-2 text-2xl opacity-30">★</div>
          <div className="absolute bottom-2 right-4 text-lg opacity-20">★</div>
        </div>

        <div className="text-xs text-gray-600">
          <div>Votre essai gratuit se termine dans 6 jours</div>
          <Button variant="link" className="h-auto p-0 text-xs text-blue-600">
            Mettre à niveau maintenant
          </Button>
        </div>
      </div>

      <MediaLibraryModal
        open={mediaLibraryOpen}
        onOpenChange={setMediaLibraryOpen}
      />
    </aside>
  );
}
