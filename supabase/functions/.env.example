# Utilisé par `npm run functions:serve:extract-colors`
# Copier vers supabase/functions/.env (ne pas committer .env)
# Les valeurs sont les mêmes que dans le tableau Supabase (Paramètres > API).

SUPABASE_URL=https://VOTRE_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clé maître AES-256 (32 octets) pour chiffrer les jetons LLM — générer avec :
#   openssl rand -hex 32
# En production : Secrets Edge Function / Dashboard Supabase (pas dans le dépôt).
PLATFORM_LLM_MASTER_KEY_HEX=
