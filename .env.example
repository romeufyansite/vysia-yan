# Copier ce fichier vers .env et renseigner les valeurs (voir tableau Supabase : Paramètres > API).

VITE_SUPABASE_URL=https://VOTRE_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Gestion IA (admin) : déployer la fonction Edge `platform-llm-admin` et renseigner le secret projet
# PLATFORM_LLM_MASTER_KEY_HEX — voir supabase/functions/.env.example (openssl rand -hex 32).

# ── Développement uniquement ──
# Si la fonction Edge n’est pas encore publiée, lancer dans un second terminal :
#   npm run functions:serve:extract-colors
# puis créer supabase/functions/.env (voir supabase/functions/.env.example), décommenter la ligne suivante et redémarrer `npm run dev` :
# VITE_DEV_EDGE_FUNCTIONS_ORIGIN=http://127.0.0.1:54321
# (l’URL exacte est affichée au démarrage de `supabase functions serve`.)
